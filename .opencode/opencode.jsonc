{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@dietrichgebert/ponytail"
  ],
  "mcp": {
    "bifrost": {
      "type": "remote",
      "url": "http://localhost:8080/mcp",
      "headers": {
        "x-bf-vk": "{file:../.opencode.env}"
      },
      "enabled": true
    }
  },
  "permission": {
    "*.env": "deny"
  }
}
